import {
    Button,
    CheckBox,
    LineEdit,
    GridBox,
} from "std-widgets.slint";
import { Card, StatusBanner, CategorySpinBox, CategoryField, SettingCheckBox, PasswordField  } from "components.slint";
import { GlobalUI, FBState } from "state.slint";

export component FBPage inherits VerticalLayout {
    spacing: GlobalUI.spacing;
    vertical-stretch: 1;

    property <int> total-positions: FBState.categories.cat1 + FBState.categories.cat2 + FBState.categories.cat3 + FBState.categories.cat4 + FBState.categories.cat5 + FBState.categories.cat6 + FBState.categories.cat7 + FBState.categories.cat8;

    // Status
    if FBState.status-type != "idle": StatusBanner {
        status-type: FBState.status-type;
        status-message: FBState.status-message;
        dismiss => {
            FBState.dismiss-status();
        }
    }

    // Pfadleiste
    HorizontalLayout {
        spacing: 8px;
        LineEdit {
            text <=> FBState.folder;
            read-only: true;
            placeholder-text: "Ausgabeordner...";
            horizontal-stretch: 1;
        }

        Button {
            text: "Durchsuchen...";
            clicked => {
                FBState.select-folder();
            }
        }
    }

    // Inhalt — nimmt verfügbaren Platz, Abstände passen sich an
    VerticalLayout {
        vertical-stretch: 1;
        spacing: 4px;

        // Zielsprachen (immer sichtbar)
        Card {
            title: "Zielsprachen";
            vertical-stretch: 0;
            VerticalLayout {                    
                spacing: 6px;
                property <bool> alle: FBState.langs.de && FBState.langs.en && FBState.langs.fr && FBState.langs.es && FBState.langs.pt;
                HorizontalLayout {                               
                    spacing: 16px;
                    CheckBox {
                        text: "Alle";
                        checked <=> alle;
                        toggled => {
                            FBState.langs.de = self.checked;
                            FBState.langs.en = self.checked;
                            FBState.langs.fr = self.checked;
                            FBState.langs.es = self.checked;
                            FBState.langs.pt = self.checked;
                            FBState.save-settings();
                        }
                    }

                    CheckBox { text: "Deutsch"; checked <=> FBState.langs.de; toggled => { update_langs() } }
                    CheckBox { text: "English"; checked <=> FBState.langs.en; toggled => { update_langs() } }
                    CheckBox { text: "Français"; checked <=> FBState.langs.fr; toggled => { update_langs() } }
                    CheckBox { text: "Español"; checked <=> FBState.langs.es; toggled => { update_langs() } }
                    CheckBox { text: "Português"; checked <=> FBState.langs.pt; toggled => { update_langs() } }
                    
                    // Alle Sprachen gleichzeitig aktivieren/deaktivieren
                    function update_langs() {
                            alle = FBState.langs.de && FBState.langs.en && FBState.langs.fr && FBState.langs.es && FBState.langs.pt;
                            FBState.save-settings();
                    }
                }
            }
        }

        // Kategorien & Positionen (immer sichtbar)
        Card {
            title: "Kategorien & Positionen";
            subtitle: "Gesamt: " + root.total-positions;
            vertical-stretch: 0;
        
            HorizontalLayout {
                spacing: 8px;
        
                // Linke Spalte
                GridBox {
                    horizontal-stretch: 1;
                    spacing: 2px;
                    Row { CategoryField { label: "1. Bauausgaben"; val <=> FBState.categories.cat1; } }
                    Row { CategoryField { label: "2. Investitionen"; val <=> FBState.categories.cat2; } }
                    Row { CategoryField { label: "3. Personalkosten"; val <=> FBState.categories.cat3; } }
                    Row { CategoryField { label: "4. Projektaktivitäten"; val <=> FBState.categories.cat4; } }
                }
        
                // Rechte Spalte
                GridBox {
                    horizontal-stretch: 1;
                    spacing: 2px;
                    Row { CategoryField { label: "5. Projektverwaltung"; val <=> FBState.categories.cat5; } }
                    Row { CategoryField { label: "6. Evaluierung"; val <=> FBState.categories.cat6; } }
                    Row { CategoryField { label: "7. Audit"; val <=> FBState.categories.cat7; } }
                    Row { CategoryField { label: "8. Reserve"; val <=> FBState.categories.cat8; } }
                }
            }
        }

        // Erweiterte Einstellungen (Card bleibt immer, Inhalt ein-/ausgeblendet)
        Card {
            title: "Erweiterte Einstellungen";
            vertical-stretch: 1;
            clip: true;
        
            VerticalLayout {
                visible: FBState.show-settings;
                spacing: 12px; // Etwas mehr Luft zwischen den Sektionen
        
                // --- Sektion: Version ---
                VerticalLayout {
                    spacing: 4px;
                    Text { text: "Version"; font-size: 13px; font-weight: 600; opacity: 0.8; }
                    LineEdit {
                        text <=> FBState.version;
                        placeholder-text: "z.B. v2025-1";
                        width: 160px;
                        edited => { FBState.save-settings(); }
                    }
                }
        
                // --- Sektion: Sichtbarkeit & Schutz ---
                GridBox {
                    spacing: 10px;
                    Row {
                        SettingCheckBox { text: "Spalten Q:V ausblenden"; value <=> FBState.hide-columns; }
                        SettingCheckBox { text: "Sprachblatt ausblenden"; value <=> FBState.hide-lang-sheet; }
                    }
                    Row {
                        SettingCheckBox { text: "Blattschutz"; value <=> FBState.protect-sheet; }
                        SettingCheckBox { text: "Mappenschutz"; value <=> FBState.protect-workbook; }
                    }
                }
        
                // --- Sektion: Passwörter ---
                HorizontalLayout {
                    spacing: 8px;
                    PasswordField { 
                        label: "Blatt-Passwort"; 
                        password <=> FBState.sheet-password; 
                        is-enabled: FBState.protect-sheet;
                        placeholder: "Standard: thetool";
                    }
                    PasswordField { 
                        label: "Mappen-Passwort"; 
                        password <=> FBState.workbook-password; 
                        is-enabled: FBState.protect-workbook;
                        placeholder: "Standard: thetool";
                    }
                }
        
                // --- Sektion: Berechtigungen ---
                Text {
                    text: "Erlaubte Aktionen bei Blattschutz";
                    font-size: 13px; font-weight: 600;
                    opacity: FBState.protect-sheet ? 0.6 : 0.3;
                }
        
                GridBox {
                    spacing: 2px;
                    Row {
                        SettingCheckBox { text: "Gesperrte Zellen wählen"; value <=> FBState.sheet-permissions.select-locked; is-enabled: FBState.protect-sheet; }
                        SettingCheckBox { text: "Spalten löschen"; value <=> FBState.sheet-permissions.delete-columns; is-enabled: FBState.protect-sheet; }
                    }
                    Row {
                        SettingCheckBox { text: "Freie Zellen wählen"; value <=> FBState.sheet-permissions.select-unlocked; is-enabled: FBState.protect-sheet; }
                        SettingCheckBox { text: "Zeilen löschen"; value <=> FBState.sheet-permissions.delete-rows; is-enabled: FBState.protect-sheet; }
                    }
                    Row {
                        SettingCheckBox { text: "Zellen formatieren"; value <=> FBState.sheet-permissions.format-cells; is-enabled: FBState.protect-sheet; }
                        SettingCheckBox { text: "Sortieren"; value <=> FBState.sheet-permissions.sort; is-enabled: FBState.protect-sheet; }
                    }
                    Row {
                        SettingCheckBox { text: "Spalten formatieren"; value <=> FBState.sheet-permissions.format-columns; is-enabled: FBState.protect-sheet; }
                        SettingCheckBox { text: "Autofilter"; value <=> FBState.sheet-permissions.autofilter; is-enabled: FBState.protect-sheet; }
                    }
                    Row {
                        SettingCheckBox { text: "Zeilen formatieren"; value <=> FBState.sheet-permissions.format-rows; is-enabled: FBState.protect-sheet; }
                        SettingCheckBox { text: "Pivot-Tabellen"; value <=> FBState.sheet-permissions.pivot-tables; is-enabled: FBState.protect-sheet; }
                    }
                    Row {
                        SettingCheckBox { text: "Spalten einfügen"; value <=> FBState.sheet-permissions.insert-columns; is-enabled: FBState.protect-sheet; }
                        SettingCheckBox { text: "Objekte bearbeiten"; value <=> FBState.sheet-permissions.edit-objects; is-enabled: FBState.protect-sheet; }
                    }
                    Row {
                        SettingCheckBox { text: "Zeilen einfügen"; value <=> FBState.sheet-permissions.insert-rows; is-enabled: FBState.protect-sheet; }
                        SettingCheckBox { text: "Szenarien"; value <=> FBState.sheet-permissions.edit-scenarios; is-enabled: FBState.protect-sheet; }
                    }
                    Row {
                        SettingCheckBox { text: "Links einfügen"; value <=> FBState.sheet-permissions.insert-hyperlinks; is-enabled: FBState.protect-sheet; }
                        SettingCheckBox { text: "Inhalte schützen"; value <=> FBState.sheet-permissions.contents; is-enabled: FBState.protect-sheet; }
                    }
                }
            }
        }
    }

    // Aktionsleiste
    HorizontalLayout {
        padding-top: 6px;
        spacing: 12px;

        Button {
            text: FBState.show-settings ? "Einstellungen ▲" : "Einstellungen ▼";
            clicked => {
                FBState.toggle-settings();
            }
        }

        Button {
            text: "Zurücksetzen";
            enabled: FBState.status-type != "pending";
            clicked => {
                FBState.reset();
            }
        }

        Rectangle {
            horizontal-stretch: 1;
        }

        Button {
            text: FBState.status-type == "pending" ? "Wird erstellt..." : "Berichte generieren";
            primary: true;
            enabled: FBState.folder != "" && FBState.version != "" && FBState.status-type != "pending" && (FBState.langs.de || FBState.langs.en || FBState.langs.fr || FBState.langs.es || FBState.langs.pt);
            clicked => {
                FBState.generate-report();
            }
            width: 200px;
        }
    }
}
