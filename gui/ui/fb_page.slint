import {
    Button,
    CheckBox,
    LineEdit,
    GridBox,
    Palette,
} from "std-widgets.slint";
import { Card, StatusBanner, CategorySpinBox } from "components.slint";
import { FBState } from "state.slint";

export component FBPage inherits VerticalLayout {
    spacing: 4px;
    vertical-stretch: 1;

    property <int> total-positions: FBState.categories.cat1 + FBState.categories.cat2 + FBState.categories.cat3 + FBState.categories.cat4 + FBState.categories.cat5 + FBState.categories.cat6 + FBState.categories.cat7 + FBState.categories.cat8;

    // Status
    if FBState.status-type != "idle": StatusBanner {
        status-type: FBState.status-type;
        status-message: FBState.status-message;
        dismiss => {
            FBState.dismiss-status();
        }
    }

    // Pfadleiste
    HorizontalLayout {
        spacing: 8px;
        LineEdit {
            text <=> FBState.folder;
            read-only: true;
            placeholder-text: "Zielordner...";
            horizontal-stretch: 1;
        }

        Button {
            text: "Durchsuchen...";
            clicked => {
                FBState.select-folder();
            }
        }
    }

    // Inhalt — nimmt verfügbaren Platz, Abstände passen sich an
    VerticalLayout {
        vertical-stretch: 1;
        spacing: 4px;

        // Zielsprachen (immer sichtbar)
        Card {
            title: "Zielsprachen";
            vertical-stretch: 0;
            VerticalLayout {
                spacing: 6px;
                property <bool> all-checked: FBState.langs.de && FBState.langs.en && FBState.langs.fr && FBState.langs.es && FBState.langs.pt;
                HorizontalLayout {
                    spacing: 16px;
                    CheckBox {
                        text: "Alle";
                        checked: all-checked;
                        toggled => {
                            if self.checked {
                                FBState.langs.de = true;
                                FBState.langs.en = true;
                                FBState.langs.fr = true;
                                FBState.langs.es = true;
                                FBState.langs.pt = true;
                            } else {
                                FBState.langs.de = false;
                                FBState.langs.en = false;
                                FBState.langs.fr = false;
                                FBState.langs.es = false;
                                FBState.langs.pt = false;
                            }
                            FBState.save-settings();
                        }
                    }

                    CheckBox {
                        text: "Deutsch";
                        checked <=> FBState.langs.de;
                        toggled => {
                            FBState.save-settings();
                        }
                    }

                    CheckBox {
                        text: "English";
                        checked <=> FBState.langs.en;
                        toggled => {
                            FBState.save-settings();
                        }
                    }

                    CheckBox {
                        text: "Français";
                        checked <=> FBState.langs.fr;
                        toggled => {
                            FBState.save-settings();
                        }
                    }

                    CheckBox {
                        text: "Español";
                        checked <=> FBState.langs.es;
                        toggled => {
                            FBState.save-settings();
                        }
                    }

                    CheckBox {
                        text: "Português";
                        checked <=> FBState.langs.pt;
                        toggled => {
                            FBState.save-settings();
                        }
                    }
                }
            }
        }

        // Kategorien & Positionen (immer sichtbar)
        Card {
            title: "Kategorien & Positionen";
            subtitle: "Gesamt: " + root.total-positions;
            vertical-stretch: 0;
            GridBox {
                spacing: 2px;
                Row {
                    Text {
                        text: "1. Bauausgaben";
                        font-size: 13px;
                        color: Palette.foreground;
                        opacity: 0.8;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    CategorySpinBox {
                        value <=> FBState.categories.cat1;
                        minimum: 0;
                        col: 1;
                        max-width: 120px;
                        changed => {
                            FBState.save-settings();
                        }
                    }

                    Text {
                        text: "5. Projektverwaltung";
                        font-size: 13px;
                        color: Palette.foreground;
                        opacity: 0.8;
                        vertical-alignment: center;
                        overflow: elide;
                        col: 2;
                    }

                    CategorySpinBox {
                        value <=> FBState.categories.cat5;
                        minimum: 0;
                        col: 3;
                        max-width: 120px;
                        changed => {
                            FBState.save-settings();
                        }
                    }
                }

                Row {
                    Text {
                        text: "2. Investitionen";
                        font-size: 13px;
                        color: Palette.foreground;
                        opacity: 0.8;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    CategorySpinBox {
                        value <=> FBState.categories.cat2;
                        minimum: 0;
                        col: 1;
                        max-width: 120px;
                        changed => {
                            FBState.save-settings();
                        }
                    }

                    Text {
                        text: "6. Evaluierung";
                        font-size: 13px;
                        color: Palette.foreground;
                        opacity: 0.8;
                        vertical-alignment: center;
                        overflow: elide;
                        col: 2;
                    }

                    CategorySpinBox {
                        value <=> FBState.categories.cat6;
                        minimum: 0;
                        col: 3;
                        max-width: 120px;
                        changed => {
                            FBState.save-settings();
                        }
                    }
                }

                Row {
                    Text {
                        text: "3. Personalkosten";
                        font-size: 13px;
                        color: Palette.foreground;
                        opacity: 0.8;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    CategorySpinBox {
                        value <=> FBState.categories.cat3;
                        minimum: 0;
                        col: 1;
                        max-width: 120px;
                        changed => {
                            FBState.save-settings();
                        }
                    }

                    Text {
                        text: "7. Audit";
                        font-size: 13px;
                        color: Palette.foreground;
                        opacity: 0.8;
                        vertical-alignment: center;
                        overflow: elide;
                        col: 2;
                    }

                    CategorySpinBox {
                        value <=> FBState.categories.cat7;
                        minimum: 0;
                        col: 3;
                        max-width: 120px;
                        changed => {
                            FBState.save-settings();
                        }
                    }
                }

                Row {
                    Text {
                        text: "4. Projektaktivitäten";
                        font-size: 13px;
                        color: Palette.foreground;
                        opacity: 0.8;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    CategorySpinBox {
                        value <=> FBState.categories.cat4;
                        minimum: 0;
                        col: 1;
                        max-width: 120px;
                        changed => {
                            FBState.save-settings();
                        }
                    }

                    Text {
                        text: "8. Reserve";
                        font-size: 13px;
                        color: Palette.foreground;
                        opacity: 0.8;
                        vertical-alignment: center;
                        overflow: elide;
                        col: 2;
                    }

                    CategorySpinBox {
                        value <=> FBState.categories.cat8;
                        minimum: 0;
                        col: 3;
                        max-width: 120px;
                        changed => {
                            FBState.save-settings();
                        }
                    }
                }
            }
        }

        // Erweiterte Einstellungen (Card bleibt immer, Inhalt ein-/ausgeblendet)
        Card {
            title: "Erweiterte Einstellungen";
            vertical-stretch: 1;
            min-height: 0px;
            clip: true;

            VerticalLayout {
                visible: FBState.show-settings;
                spacing: 4px;

                // Version
                VerticalLayout {
                    spacing: 8px;
                    Text {
                        text: "Version";
                        font-size: 13px;
                        font-weight: 600;
                        color: Palette.foreground;
                        opacity: 0.8;
                        vertical-alignment: center;
                    }

                    LineEdit {
                        text <=> FBState.version;
                        placeholder-text: "z.B. v2025-1";
                        width: 160px;
                        edited => {
                            FBState.save-settings();
                        }
                    }
                }

                Rectangle {
                    height: 1px;
                    background: Palette.border;
                    opacity: 0.3;
                }

                // Zusammengefasste GridBox für Sichtbarkeit und Sicherheit
                GridBox {
                    padding-left: 7px;
                    spacing: 10px;

                    // Zeile 1: Sichtbarkeit
                    Row {
                        CheckBox {
                            text: "Spalten Q:V ausblenden";
                            checked <=> FBState.hide-columns;
                            toggled => {
                                FBState.save-settings();
                            }
                        }

                        CheckBox {
                            text: "Sprachblatt ausblenden";
                            checked <=> FBState.hide-lang-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }
                    }

                    // Zeile 2: Trennlinie (spannt über beide Spalten)
                    Row {
                        Rectangle {
                            colspan: 2;
                            height: 1px;
                            background: Palette.border;
                            opacity: 0.3;
                        }
                    }

                    // Zeile 3: Excel-Sicherheit
                    Row {
                        CheckBox {
                            text: "Blattschutz";
                            checked <=> FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }

                        CheckBox {
                            text: "Mappenschutz";
                            checked <=> FBState.protect-workbook;
                            toggled => {
                                FBState.save-settings();
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        background: Palette.background;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: Palette.border;
                        horizontal-stretch: 1;
                        opacity: FBState.protect-sheet ? 1.0 : 0.5;
                        VerticalLayout {
                            padding: 10px;
                            spacing: 3px;
                            Text {
                                text: "Blatt-Passwort";
                                font-size: 13px;
                                font-weight: 600;
                                color: Palette.foreground;
                                opacity: 0.7;
                            }

                            LineEdit {
                                input-type: InputType.password;
                                placeholder-text: "Standard: thetool";
                                text <=> FBState.sheet-password;
                                enabled: FBState.protect-sheet;
                                edited => {
                                    FBState.save-settings();
                                }
                            }
                        }
                    }

                    Rectangle {
                        background: Palette.background;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: Palette.border;
                        horizontal-stretch: 1;
                        opacity: FBState.protect-workbook ? 1.0 : 0.5;
                        VerticalLayout {
                            padding: 10px;
                            spacing: 3px;
                            Text {
                                text: "Mappen-Passwort";
                                font-size: 13px;
                                font-weight: 600;
                                color: Palette.foreground;
                                opacity: 0.7;
                            }

                            LineEdit {
                                input-type: InputType.password;
                                placeholder-text: "Standard: thetool";
                                text <=> FBState.workbook-password;
                                enabled: FBState.protect-workbook;
                                edited => {
                                    FBState.save-settings();
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    height: 1px;
                    background: Palette.border;
                    opacity: 0.3;
                }

                // Blattschutz-Berechtigungen
                Text {
                    text: "Erlaubte Aktionen bei Blattschutz";
                    font-size: 13px;
                    font-weight: 600;
                    color: Palette.foreground;
                    opacity: FBState.protect-sheet ? 0.6 : 0.3;
                }

                GridBox {
                    spacing: 2px;
                    Row {
                        CheckBox {
                            text: "Gesperrte Zellen wählen";
                            checked <=> FBState.sheet-permissions.select-locked;
                            enabled: FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }

                        CheckBox {
                            text: "Spalten löschen";
                            checked <=> FBState.sheet-permissions.delete-columns;
                            enabled: FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }
                    }

                    Row {
                        CheckBox {
                            text: "Freie Zellen wählen";
                            checked <=> FBState.sheet-permissions.select-unlocked;
                            enabled: FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }

                        CheckBox {
                            text: "Zeilen löschen";
                            checked <=> FBState.sheet-permissions.delete-rows;
                            enabled: FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }
                    }

                    Row {
                        CheckBox {
                            text: "Zellen formatieren";
                            checked <=> FBState.sheet-permissions.format-cells;
                            enabled: FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }

                        CheckBox {
                            text: "Sortieren";
                            checked <=> FBState.sheet-permissions.sort;
                            enabled: FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }
                    }

                    Row {
                        CheckBox {
                            text: "Spalten formatieren";
                            checked <=> FBState.sheet-permissions.format-columns;
                            enabled: FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }

                        CheckBox {
                            text: "Autofilter";
                            checked <=> FBState.sheet-permissions.autofilter;
                            enabled: FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }
                    }

                    Row {
                        CheckBox {
                            text: "Zeilen formatieren";
                            checked <=> FBState.sheet-permissions.format-rows;
                            enabled: FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }

                        CheckBox {
                            text: "Pivot-Tabellen";
                            checked <=> FBState.sheet-permissions.pivot-tables;
                            enabled: FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }
                    }

                    Row {
                        CheckBox {
                            text: "Spalten einfügen";
                            checked <=> FBState.sheet-permissions.insert-columns;
                            enabled: FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }

                        CheckBox {
                            text: "Objekte bearbeiten";
                            checked <=> FBState.sheet-permissions.edit-objects;
                            enabled: FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }
                    }

                    Row {
                        CheckBox {
                            text: "Zeilen einfügen";
                            checked <=> FBState.sheet-permissions.insert-rows;
                            enabled: FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }

                        CheckBox {
                            text: "Szenarien";
                            checked <=> FBState.sheet-permissions.edit-scenarios;
                            enabled: FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }
                    }

                    Row {
                        CheckBox {
                            text: "Links einfügen";
                            checked <=> FBState.sheet-permissions.insert-hyperlinks;
                            enabled: FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }

                        CheckBox {
                            text: "Inhalte schützen";
                            checked <=> FBState.sheet-permissions.contents;
                            enabled: FBState.protect-sheet;
                            toggled => {
                                FBState.save-settings();
                            }
                        }
                    }
                }
            }
        }
    }

    // Aktionsleiste
    HorizontalLayout {
        padding-top: 6px;
        spacing: 12px;

        Button {
            text: FBState.show-settings ? "Einstellungen ▲" : "Einstellungen ▼";
            clicked => {
                FBState.toggle-settings();
            }
        }

        Button {
            text: "Zurücksetzen";
            enabled: FBState.status-type != "pending";
            clicked => {
                FBState.reset();
            }
        }

        Rectangle {
            horizontal-stretch: 1;
        }

        Button {
            text: FBState.status-type == "pending" ? "Wird erstellt..." : "Berichte generieren";
            primary: true;
            enabled: FBState.folder != "" && FBState.version != "" && FBState.status-type != "pending" && (FBState.langs.de || FBState.langs.en || FBState.langs.fr || FBState.langs.es || FBState.langs.pt);
            clicked => {
                FBState.generate-report();
            }
            width: 200px;
        }
    }
}
