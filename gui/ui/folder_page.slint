import { Button, CheckBox, LineEdit, Palette, ScrollView } from "std-widgets.slint";
import { Card, StatusBanner, PathInputField, ProjectNameField } from "components.slint";
import { FolderState, GlobalUI } from "state.slint";

export component FolderPage inherits VerticalLayout {
    spacing: GlobalUI.spacing;
    
    // --- 1. FIXED HEADER (Status) ---
    if FolderState.status-type != "idle": StatusBanner {
        status-type: FolderState.status-type;
        status-message: FolderState.status-message;
        dismiss => { FolderState.dismiss-status(); }
    }

    // --- 2. SCROLLABLE CONTENT ---
    ScrollView {
        vertical-stretch: 1;
        viewport-height: folder-scroll-layout.min-height;

        folder-scroll-layout := VerticalLayout {
            spacing: 20px;
            padding-right: 16px; // Platz für die Scrollbar

            // --- SEKTION 1: EINZELNER ORDNER ---
            HorizontalLayout {
                alignment: start;
                Card {
                    title: "Einzelner Ordner";
                    width: 75%;
                    VerticalLayout {
                        spacing: 15px;

                        ProjectNameField {
                            project-name <=> FolderState.project-name;
                            skip-validation <=> FolderState.skip-validation;
                            target-folder: FolderState.target-folder;
                            folder-exists: FolderState.folder-exists;
                            validated => { FolderState.validate-project-name(); }
                        }

                        PathInputField {
                            label: "Excel-Vorlage";
                            value <=> FolderState.template-file;
                            clicked => { FolderState.select-template(); }
                        }

                        PathInputField {
                            label: "Zielverzeichnis";
                            value <=> FolderState.target-folder;
                            clicked => { FolderState.select-folder(); }
                        }

                        // Footer Buttons innerhalb der Card
                        HorizontalLayout {
                            spacing: 12px;
                            alignment: end;
                            Button {
                                text: "Zurücksetzen";
                                clicked => { FolderState.reset(); }
                            }
                            Button {
                                text: "Ordner erstellen";
                                primary: true;
                                enabled: FolderState.target-folder != "" && FolderState.template-file != "" && FolderState.project-name-valid && FolderState.status-type != "pending";
                                clicked => { FolderState.create-folders(); }
                            }
                        }
                    }
                }
            }

            // --- SEKTION 2: CSV-IMPORT ---
            HorizontalLayout {
                alignment: start;
                Card {
                    title: "CSV-Import";
                    width: 75%;
                    VerticalLayout {
                        spacing: 15px;
                        Text {
                            text: "Erstellt für jede Projektnummer in der CSV-Datei automatisch die Ordnerstruktur.";
                            font-size: 12px; opacity: 0.5; wrap: word-wrap;
                        }

                        PathInputField {
                            label: "CSV-Datei";
                            value <=> FolderState.csv-file;
                            clicked => { FolderState.select-csv-file(); }
                        }

                        PathInputField {
                            label: "Zielverzeichnis";
                            value <=> FolderState.csv-target-folder;
                            clicked => { FolderState.select-csv-target(); }
                        }

                        HorizontalLayout {
                            alignment: end;
                            Button {
                                text: "Importieren";
                                primary: true;
                                enabled: FolderState.csv-file != "" && FolderState.csv-target-folder != "" && FolderState.template-file != "" && FolderState.status-type != "pending";
                                clicked => { FolderState.import-csv(); }
                            }
                        }
                    }
                }
            }
        }
    }
}
