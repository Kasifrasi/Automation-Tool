import { Button, LineEdit, Palette, StandardTableView } from "std-widgets.slint";
import { Card, StatusBanner } from "components.slint";
import { BudgetState } from "state.slint";

export component BudgetPage inherits VerticalLayout {
    spacing: 10px;
    vertical-stretch: 1;

    // Status
    if BudgetState.status-type != "idle" : StatusBanner {
        status-type: BudgetState.status-type;
        status-message: BudgetState.status-message;
        dismiss => { BudgetState.dismiss-status(); }
    }

    // Ordner-Auswahl (kompakt)
    HorizontalLayout {
        spacing: 8px;
        LineEdit { text <=> BudgetState.src-folder; read-only: true; placeholder-text: "Quellordner..."; horizontal-stretch: 1; }
        Button { text: "Quelle..."; clicked => { BudgetState.select-src(); } }
        LineEdit { text <=> BudgetState.out-folder; read-only: true; placeholder-text: "Ausgabeordner..."; horizontal-stretch: 1; }
        Button { text: "Ausgabe..."; clicked => { BudgetState.select-out(); } }
    }

    // Ergebnis-Tabelle
    Card {
        title: "Ergebnisse";
        vertical-stretch: 1;

        StandardTableView {
            columns: BudgetState.table-columns;
            rows: BudgetState.table-data;
        }
    }

    // Aktionsleiste
    HorizontalLayout {
        spacing: 12px;

        Button { text: "Zurücksetzen"; clicked => { BudgetState.do-reset(); } }

        Rectangle { horizontal-stretch: 1; }

        Button { text: "Ansicht → CSV"; clicked => { BudgetState.do-export-txt(); } }
        Button { text: "Ansicht → Excel"; clicked => { BudgetState.do-export-excel(); } }

        Button {
            text: BudgetState.status-type == "pending" ? "Scannt..." : "Scan starten (F5)";
            primary: true;
            enabled: BudgetState.src-folder != "" && BudgetState.out-folder != "" && BudgetState.status-type != "pending";
            clicked => { BudgetState.scan(); }
            width: 200px;
        }
    }
}
